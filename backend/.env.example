DATABASE_URL="postgresql://postgres:postgres@localhost:5432/gathrio_db"

JWT_SECRET="replace-with-strong-random-jwt-secret"

JWT_REFRESH_SECRET="replace-with-strong-random-jwt-refresh-secret"

NODE_ENV="development"
PORT="5000"

FRONTEND_URL="http://localhost:3001"

# Email provider options (use either SendGrid OR SMTP values)
SENDGRID_API_KEY=""
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
FROM_EMAIL="noreply@gathrio.com"

# Redis (optional)
REDIS_URL="redis://localhost:6379"